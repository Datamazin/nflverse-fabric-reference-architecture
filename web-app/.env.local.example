# Environment Variables for NFL Data Agent Chat App
# Copy this file to .env.local and fill in your values

# Azure AD / Entra ID
NEXT_PUBLIC_AZURE_CLIENT_ID=your-app-client-id
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000

# Backend (server-side only - never exposed to browser)
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# Fabric Data Agent Configuration
FABRIC_WORKSPACE_ID=b3f22323-864a-451d-9711-fe344c8e4380
FABRIC_SM_AGENT_ID=ecab4318-c696-45e5-9823-94c3b5cb2ab0
FABRIC_LAKEHOUSE_AGENT_ID=your-lakehouse-data-agent-id

# Sample questions shown on the landing/empty chat state (pipe-separated)
NEXT_PUBLIC_SAMPLE_QUESTION_1=How many regular season games were played in 2025?
NEXT_PUBLIC_SAMPLE_QUESTION_2=Which team had the best red zone touchdown rate in the 2025 regular season?
NEXT_PUBLIC_SAMPLE_QUESTION_3=List the top 5 quarterbacks by passing yards in the 2025 regular season.
